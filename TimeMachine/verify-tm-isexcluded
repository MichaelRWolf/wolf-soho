#!/usr/bin/env bash
# verify-tm-isexcluded
#
# Verifies Time Machine inclusion/exclusion state against a YAML config.
# Outputs TAP (Test Anything Protocol). Does not change any TM settings.
#
# Usage:
#   Stand-alone (run from TimeMachine dir or same dir as YAML):
#     ./verify-tm-isexcluded
#     ./verify-tm-isexcluded path/to/tm-exclude-include.yaml
#
#   As part of a test runner (e.g. prove, pytest-tap, or any TAP consumer):
#     prove ./verify-tm-isexcluded
#     ./verify-tm-isexcluded | prove -
#
# Requires: tmutil, Ruby (macOS default) for YAML parsing, or set PARSE_YAML_CMD.
# YAML file: tm-exclude-include.yaml in script directory, or pass as first argument.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
YAML_FILE="${1:-$SCRIPT_DIR/tm-exclude-include.yaml}"

if [[ ! -f "$YAML_FILE" ]]; then
  echo "Bail out! YAML file not found: $YAML_FILE"
  exit 1
fi

# TAP helpers. Use _tap_test_number (global); ok/skip/todo increment it.
tap_plan() { echo "TAP version 13"; echo "1..$1"; }
ok() {
  local result=$1 desc=$2
  if [[ "${result:-1}" -eq 0 ]]; then
    echo "ok $_tap_test_number - $desc"
  else
    echo "not ok $_tap_test_number - $desc"
  fi
  _tap_test_number=$((_tap_test_number + 1))
}
skip() {
  local reason=$1 desc=$2
  echo "ok $_tap_test_number - $desc # skip $reason"
  _tap_test_number=$((_tap_test_number + 1))
}
todo() {
  local result=$1 desc=$2 reason=${3:-}
  if [[ "${result:-1}" -eq 0 ]]; then
    echo "ok $_tap_test_number - $desc # TODO $reason"
  else
    echo "not ok $_tap_test_number - $desc # TODO $reason"
  fi
  _tap_test_number=$((_tap_test_number + 1))
}

# Normalize path to absolute form for comparison (~ and ~user expanded, no trailing slash).
normalize_path() {
  local path="$1"
  [[ -z "$path" ]] && return
  ruby -e "puts File.expand_path(ARGV[0])" "$path" 2>/dev/null || echo "$path"
}

# Parse YAML list for key (must_include or must_exclude). Override with PARSE_YAML_CMD if needed.
parse_list() {
  local key="$1"
  if [[ -n "${PARSE_YAML_CMD:-}" ]]; then
    eval "$PARSE_YAML_CMD" "$YAML_FILE" "$key"
  else
    ruby -r yaml -e "
      data = YAML.load_file('$YAML_FILE')
      list = data['$key'] || []
      list.each { |p| puts p }
    " 2>/dev/null
  fi
}

# Verify each path in must_include is reported as Included by tmutil.
# Skips with # skip if the location does not exist (e.g. No such file or directory).
# Paths from YAML are normalized so ~ and ~user work.
verify_inclusions() {
  local path
  while IFS= read -r path; do
    [[ -z "$path" ]] && continue
    path=$(normalize_path "$path")
    [[ -z "$path" ]] && continue
    if [[ ! -e "$path" ]]; then
      skip "No such file or directory" "$path is included"
    else
      tmutil isexcluded "$path" 2>/dev/null | grep -q '\[Included\]' && result=0 || result=1
      ok $result "$path is included"
    fi
  done < <(parse_list must_include)
}

# Verify each path in must_exclude is reported as Excluded by tmutil.
# Skips with # skip if the location does not exist (e.g. No such file or directory).
# Paths from YAML are normalized so ~ and ~user work.
verify_exclusions() {
  local path
  while IFS= read -r path; do
    [[ -z "$path" ]] && continue
    path=$(normalize_path "$path")
    [[ -z "$path" ]] && continue
    if [[ ! -e "$path" ]]; then
      skip "No such file or directory" "$path is excluded"
    else
      tmutil isexcluded "$path" 2>/dev/null | grep -q '\[Excluded\]' && result=0 || result=1
      ok $result "$path is excluded"
    fi
  done < <(parse_list must_exclude)
}

# Count entries for TAP plan
count_includes() { parse_list must_include | grep -c . || true; }
count_excludes() { parse_list must_exclude | grep -c . || true; }

# System exclusions (SkipPaths from TM plist). One path per line; empty if unreadable.
get_system_exclusions() {
  local i=0
  local path
  while true; do
    path=$(/usr/libexec/PlistBuddy -c "Print SkipPaths:$i" /Library/Preferences/com.apple.TimeMachine.plist 2>/dev/null) || break
    [[ -n "$path" ]] && echo "$path"
    ((i++)) || true
  done
}

# Time Machine backup-exclude xattr (value "1" = excluded). Same on Monterey and Sequoia.
TM_BACKUP_EXCLUDE_XATTR="com.apple.metadata:com_apple_backup_excludeItem"

# Get normalized SkipPaths (one per line) for comparison.
get_normalized_skip_paths() {
  local path
  while IFS= read -r path; do
    [[ -z "$path" ]] && continue
    normalize_path "$path"
  done < <(get_system_exclusions)
}

# Output exclusion-source annotation for path: "TM list", "TM list via parent", "xattr", "xattr via parent", or "*NEITHER*" (1 or 2 tokens).
# Path may appear in both must_exclude and SkipPaths sections; each section shows its own annotation.
# Uses _cached_normalized_skip_paths if set (call set_cached_normalized_skip_paths once before report).
get_exclusion_source_annotation() {
  local path="$1"
  local norm_path
  norm_path=$(normalize_path "$path")
  [[ -z "$norm_path" ]] && echo "*NEITHER*" && return

  local tm_exact=0 tm_via_parent=0
  local sp
  while IFS= read -r sp; do
    [[ -z "$sp" ]] && continue
    if [[ "$norm_path" == "$sp" ]]; then
      tm_exact=1
      break
    fi
    if [[ "$norm_path" == "$sp"/* ]]; then
      tm_via_parent=1
      break
    fi
  done <<< "${_cached_normalized_skip_paths:-$(get_normalized_skip_paths)}"

  local xattr_exact=0 xattr_via_parent=0
  if [[ -e "$norm_path" ]]; then
    local check="$norm_path"
    while [[ -n "$check" ]]; do
      if xattr -p "$TM_BACKUP_EXCLUDE_XATTR" "$check" 2>/dev/null | grep -q '^1$'; then
        if [[ "$check" == "$norm_path" ]]; then
          xattr_exact=1
        else
          xattr_via_parent=1
        fi
        break
      fi
      [[ "$check" == "/" ]] && break
      local parent
      parent=$(dirname "$check")
      [[ "$parent" == "$check" ]] && break
      check="$parent"
    done
  fi

  local tokens=""
  if [[ "$tm_exact" -eq 1 ]]; then
    tokens="TM list"
  elif [[ "$tm_via_parent" -eq 1 ]]; then
    tokens="TM list via parent"
  fi
  if [[ "$xattr_exact" -eq 1 ]]; then
    [[ -n "$tokens" ]] && tokens="$tokens, xattr" || tokens="xattr"
  elif [[ "$xattr_via_parent" -eq 1 ]]; then
    [[ -n "$tokens" ]] && tokens="$tokens, xattr via parent" || tokens="xattr via parent"
  fi
  if [[ -z "$tokens" ]]; then
    tokens="*NEITHER*"
  fi
  echo "$tokens"
}

# Paths in system but not in must_exclude (inconsistent). One path per line.
# Compares normalized absolute paths so ~/repos, ~michael/repos, /Users/michael/repos match.
get_inconsistent_exclusions() {
  local declared_normalized
  declared_normalized=$(parse_list must_exclude | while IFS= read -r p; do
    [[ -z "$p" ]] && continue
    normalize_path "$p"
  done | sort -u)
  get_system_exclusions | while IFS= read -r path; do
    [[ -z "$path" ]] && continue
    if ! echo "$declared_normalized" | grep -Fqx "$(normalize_path "$path")"; then
      echo "$path"
    fi
  done
}

total=$(($(count_includes) + $(count_excludes)))
inconsistent_count=$(get_inconsistent_exclusions | grep -c . || true)
total=$((total + inconsistent_count))
if [[ "$total" -eq 0 ]]; then
  echo "Bail out! No must_include or must_exclude entries in $YAML_FILE"
  exit 1
fi

tap_plan "$total"
_tap_test_number=1
verify_inclusions
verify_exclusions

# Warn for each system exclusion not in declaration file (TAP TODO)
while IFS= read -r path; do
  [[ -z "$path" ]] && continue
  todo 1 "$path" "Remove from system or add to declaration file"
done < <(get_inconsistent_exclusions)

# Final report (TAP comments; invisible to prove, visible to reader).
# A path may appear in both must_exclude and SkipPaths; each section shows its own annotation.
_cached_normalized_skip_paths=$(get_normalized_skip_paths)
echo "#"
echo "# --- Time Machine report ---"
echo "# must_include (from $YAML_FILE):"
parse_list must_include | while IFS= read -r p; do
  [[ -z "$p" ]] && continue
  echo "#   $(normalize_path "$p")"
done
echo "# must_exclude (from $YAML_FILE); source = TM list, xattr, or *NEITHER*:"
parse_list must_exclude | while IFS= read -r p; do
  [[ -z "$p" ]] && continue
  norm=$(normalize_path "$p")
  ann=$(get_exclusion_source_annotation "$p")
  echo "#   $norm   ($ann)"
done
echo "# SkipPaths (system plist); source = TM list, xattr, or *NEITHER*:"
get_system_exclusions | while IFS= read -r path; do
  [[ -z "$path" ]] && continue
  norm=$(normalize_path "$path")
  ann=$(get_exclusion_source_annotation "$path")
  echo "#   $norm   ($ann)"
done
echo "# ---"
