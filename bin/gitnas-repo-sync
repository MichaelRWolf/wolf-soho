#!/bin/bash
set -euo pipefail

REMOTE_NAME="nas"
HOST=$(hostname -s)

push_canonical() {
    git -C "$REPO_ROOT" push "$REMOTE_NAME" "$branch" 2>/dev/null
}

push_per_host_namespaced_branch() {
    # Canonical push failed (non-fast-forward): this machine has diverged from
    # whatever another machine already pushed to NAS. Rather than fail and lose
    # this machine's work, push to a per-host namespaced branch
    # (e.g. wolf-air/main) so the commits are safely stored on NAS.
    # Nothing is overwritten; both machines' work coexists until origin becomes
    # the reconciliation point and a future canonical push succeeds.
    if git -C "$REPO_ROOT" push "$REMOTE_NAME" "HEAD:refs/heads/${HOST}/${branch}"; then
        echo "safety-net push succeeded: ${HOST}/${branch}"
    else
        echo "safety-net push FAILED: ${HOST}/${branch}" >&2
        return 1
    fi
}

canonical_branch_contains_all_commits_of_safety_branch() {
    # True when every commit in the namespaced safety-net branch is already
    # reachable via the canonical branch -- i.e. the safety branch adds nothing new.
    local ns_ref="refs/remotes/${REMOTE_NAME}/${HOST}/${branch}"
    local canon_ref="refs/remotes/${REMOTE_NAME}/${branch}"
    git -C "$REPO_ROOT" rev-parse --verify "$ns_ref" &>/dev/null && \
        git -C "$REPO_ROOT" merge-base --is-ancestor "$ns_ref" "$canon_ref" 2>/dev/null
}

cleanup_stale_safety_branch() {
    git -C "$REPO_ROOT" fetch "$REMOTE_NAME" 2>/dev/null || true
    if canonical_branch_contains_all_commits_of_safety_branch; then
        git -C "$REPO_ROOT" push "$REMOTE_NAME" --delete "${HOST}/${branch}"
        echo "cleanup succeeded: removed stale safety branch ${HOST}/${branch}"
    fi
}

REPO_ROOT=$(git rev-parse --show-toplevel)
branch=$(git -C "$REPO_ROOT" symbolic-ref --short HEAD 2>/dev/null) \
    || { echo "SKIP (detached HEAD): $REPO_ROOT" >&2; exit 1; }
echo "=== $(gh repo view --json name --jq '.name') ($branch) ==="

if push_canonical; then
    echo "canonical push succeeded: ${branch}"
    # Clean up any namespaced safety-net branch left from a prior diverged run.
    cleanup_stale_safety_branch
else
    echo "canonical push failed (diverged) -- falling back to safety-net branch" >&2
    push_per_host_namespaced_branch
fi
