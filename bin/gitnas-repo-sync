#!/bin/bash
set -euo pipefail

REMOTE_NAME="nas"

REPO_ROOT=$(git rev-parse --show-toplevel)
branch=$(git -C "$REPO_ROOT" symbolic-ref --short HEAD 2>/dev/null) || { echo "SKIP (detached HEAD): $REPO_ROOT" >&2; exit 1; }
echo "=== $(gh repo view --json name --jq '.name') ($branch) ==="
git -C "$REPO_ROOT" push "$REMOTE_NAME" "$branch"
