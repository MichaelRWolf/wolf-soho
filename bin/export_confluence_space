#!/usr/bin/env bash
# Export a single Confluence Cloud space to XML and HTML zip archives.
#
# Usage: export_confluence_space SPACEKEY [OUTPUT_DIR]
#
# Token storage (choose one — never hardcode):
#   Keychain (recommended):
#     security add-generic-password \
#       -a 'michaelrwolf@att.net' \
#       -s 'atlassian-api-token' \
#       -w 'YOUR_TOKEN_HERE'
#   Env var (fallback):
#     export ATLASSIAN_API_TOKEN='YOUR_TOKEN_HERE'
#
# Get/create a token at:
#   https://id.atlassian.com  →  Security  →  API tokens
#   (Available on all plan tiers — free, standard, premium)
#   NOTE: tokens created before Dec 2024 expire Mar–May 2026; create a fresh one.

set -euo pipefail

SITE="wolfenterprises.atlassian.net"
EMAIL="michaelrwolf@att.net"
KEYCHAIN_SERVICE="atlassian-api-token"

# --------------------------------------------------------------------------- #
# Dependency check
# --------------------------------------------------------------------------- #
need() { command -v "$1" >/dev/null 2>&1 || { echo "ERROR: missing dependency: $1" >&2; exit 1; }; }
need curl
need jq

# --------------------------------------------------------------------------- #
# Token resolution: Keychain → env var  (never hardcoded)
# --------------------------------------------------------------------------- #
TOKEN=""
if TOKEN=$(security find-generic-password -a "$EMAIL" -s "$KEYCHAIN_SERVICE" -w 2>/dev/null) && [[ -n "$TOKEN" ]]; then
    : # resolved from Keychain
elif [[ -n "${ATLASSIAN_API_TOKEN:-}" ]]; then
    TOKEN="$ATLASSIAN_API_TOKEN"
else
    cat >&2 <<EOF
ERROR: No Atlassian API token found.

Option 1 — Keychain (recommended, persists across sessions):
  security add-generic-password \\
    -a '$EMAIL' \\
    -s '$KEYCHAIN_SERVICE' \\
    -w 'YOUR_TOKEN_HERE'

Option 2 — Environment variable (for this session only):
  export ATLASSIAN_API_TOKEN='YOUR_TOKEN_HERE'

Get/create a token at:
  https://id.atlassian.com  →  Security  →  API tokens
EOF
    exit 1
fi

# --------------------------------------------------------------------------- #
# Arguments
# --------------------------------------------------------------------------- #
SPACEKEY="${1:?Usage: $(basename "$0") SPACEKEY [OUTPUT_DIR]}"
OUTPUT_DIR="${2:-${HOME}/confluence_exports}"
DATE=$(date +%Y-%m-%d)
mkdir -p "$OUTPUT_DIR"

# --------------------------------------------------------------------------- #
# Export XML via the .action URL (same endpoint the Confluence UI uses).
# Works for all key types including personal spaces (~651898979).
# --------------------------------------------------------------------------- #
export_xml() {
    local url="https://${SITE}/wiki/spaces/exportspacexml.action?key=${SPACEKEY}"
    local outfile="${OUTPUT_DIR}/${SPACEKEY}_${DATE}_XML.zip"

    echo "  [XML] ${SPACEKEY} → ${outfile}"
    echo "  URL: ${url}"

    http_code=$(curl -s \
        -w "%{http_code}" \
        -u "${EMAIL}:${TOKEN}" \
        -L \
        -o "$outfile" \
        "$url")

    if [[ "$http_code" -ge 200 && "$http_code" -lt 300 ]] && [[ -s "$outfile" ]]; then
        echo "  ✓  $(du -sh "$outfile" | cut -f1)  ${outfile}"
    else
        echo "  ✗  Export failed (HTTP ${http_code})" >&2
        if [[ -f "$outfile" ]]; then
            echo "  Response snippet:" >&2
            head -5 "$outfile" >&2
            rm -f "$outfile"
        fi
        echo "" >&2
        echo "  To export manually, open in browser:" >&2
        echo "  ${url}" >&2
        return 1
    fi
}

# --------------------------------------------------------------------------- #
# Run
# --------------------------------------------------------------------------- #
echo "Exporting space: ${SPACEKEY}"
export_xml
echo "Done: ${SPACEKEY}"
