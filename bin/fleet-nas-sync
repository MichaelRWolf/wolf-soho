#!/bin/bash
set -euo pipefail

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
SCRIPT_NAME=$(basename "${SCRIPT_SOURCE}")

NAS_HOST="wolfden-nas"
NAS_PORT=22
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/${SCRIPT_NAME}"
STATE_FILE="$STATE_DIR/last-success"
LOG_FILE="$HOME/Library/Logs/${SCRIPT_NAME}.log"
VERBOSE=0
[[ "${1:-}" == "--verbose" ]] && VERBOSE=1

# Always tee to log file -- consistent output whether run ad-hoc or via launchd
mkdir -p "$(dirname "$LOG_FILE")"
exec > >(tee -a "$LOG_FILE") 2>&1

# Bootstrap shlib
_libload="${SHELL_LIB_PATH:+${SHELL_LIB_PATH%%:*}/libload.sh}"
[[ ! -f "$_libload" ]] && _libload="$HOME/repos/Portable_Profile/shlib/libload.sh"
# shellcheck disable=SC1090
source "$_libload" 2>/dev/null && libload log.sh 2>/dev/null || true

log_info()    { info "$*"; }
log_warning() { warn "$*"; }

log_info "Begin ${SCRIPT_NAME}"

# Connectivity guard -- explicit TCP check, no per-repo SSH timeouts
timeout 2 nc -z -w 2 "$NAS_HOST" "$NAS_PORT" 2>/dev/null || {
    log_info "NAS unreachable ($NAS_HOST:$NAS_PORT) - exiting"
    exit 0
}

# Staleness warning
mkdir -p "$STATE_DIR"
if [[ ! -f "$STATE_FILE" ]] || \
   find "$STATE_FILE" -mtime +14 -print 2>/dev/null | grep -q .; then
    log_warning "No successful NAS sync in 14+ days"
fi

failures=0

for repo in ~/repos/*/; do
    [[ -d "${repo}.git" ]] || continue
    git -C "$repo" remote get-url nas &>/dev/null || {
        [[ "$VERBOSE" -eq 1 ]] && log_info "skip (no nas remote): $(basename "$repo")"
        continue
    }
    GITNAS_ERROR_FILE="/tmp/${SCRIPT_NAME}-err"
    if (cd "$repo" && gitnas-repo-sync) 2> "${GITNAS_ERROR_FILE}"; then
        [[ "$VERBOSE" -eq 1 ]] && log_info "synced: $(basename "$repo")"
    else
        log_warning "FAILED: $(basename "$repo")"
        cat "${GITNAS_ERROR_FILE}" >&2
        (( failures++ )) || true
    fi
done

if [[ "$failures" -eq 0 ]]; then
    date -u '+%Y-%m-%dT%H:%M:%SZ' > "$STATE_FILE"
fi

log_info "End ${SCRIPT_NAME}"
[[ "$failures" -eq 0 ]]
